# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to true to bypass the Claude API entirely.
# The built-in rule-based underwriter will run instead — no API key required.
DEMO_MODE=true

# ── Anthropic Claude API ───────────────────────────────────────────────────────
# Only required when DEMO_MODE=false
ANTHROPIC_API_KEY=your_key_here

# ── PostgreSQL connection string ───────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/mortgage_agent

# ── Application port ───────────────────────────────────────────────────────────
PORT=3000

# ── Node environment ───────────────────────────────────────────────────────────
NODE_ENV=development
